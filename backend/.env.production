# 数据库配置
DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql://user:password@db:5432/qingjili

# Redis配置
REDIS_URL=redis://redis:6379/0

# 安全配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 允许的主机
ALLOWED_HOSTS=api.qingjili.com,localhost,127.0.0.1

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://www.qingjili.com

# 环境
ENVIRONMENT=production

# 限流配置
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# 日志配置
LOG_LEVEL=INFO

# 文件上传配置
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# API配置
API_V1_PREFIX=/api/v1

# NVIDIA API配置
NVIDIA_API_KEY=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
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# OpenAI配置（备用）
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
