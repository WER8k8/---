# ===========================================
# 生产环境配置文件 - 请妥善保管此文件
# 所有敏感信息必须通过环境变量设置
# ===========================================

# 域名配置
DOMAIN=youding.com

# 数据库配置
DB_NAME=youding_seo_prod
DB_USER=youding_prod
DB_PASSWORD=your-secure-db-password-change-in-production

# Redis配置
REDIS_URL=redis://localhost:6379/0

# MinIO 文件存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=youding_admin_prod
MINIO_SECRET_KEY=your-minio-secret-key-change-in-production

# JWT 认证 - 必须使用强随机密钥
JWT_SECRET_KEY=your-32-character-or-longer-secret-key-must-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# AI 服务 API密钥
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
AI_GEMINI_API_KEY=
AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com

# NVIDIA AI API
AI_NVIDIA_API_KEY=your-nvidia-api-key
AI_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
AI_NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Celery 任务队列
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 安全配置
DEBUG=false
ALLOWED_HOSTS=youding.com,www.youding.com
CORS_ORIGINS=https://youding.com

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/youding/app.log