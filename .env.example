# 后端配置
DATABASE_URL=postgresql://youding:youding123@localhost:5432/youding_seo
REDIS_URL=redis://localhost:6379/0

# MinIO 文件存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=youding_admin
MINIO_SECRET_KEY=youding_secret_key

# JWT 认证
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# AI 服务 API密钥（至少配置一个即可使用）
AI_OPENAI_API_KEY=
AI_ANTHROPIC_API_KEY=
AI_GEMINI_API_KEY=

# NVIDIA AI API（支持Claude模型）
AI_NVIDIA_API_KEY=
AI_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
AI_NVIDIA_MODEL=anthropic/claude-3-5-opus-4.7-20250423

# Celery 任务队列
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# 前端配置（Nuxt.js）
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NUXT_PUBLIC_SITE_URL=http://localhost:3000
