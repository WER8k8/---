{
  "name": "seo-matrix-backend",
  "version": "1.0.0",
  "description": "全国县域建材SEO矩阵AI全自动后台系统 - Node.js后端",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "test": "jest",
    "lint": "eslint src/",
    "db:migrate": "sequelize db:migrate",
    "db:seed": "sequelize db:seed:all",
    "init:data": "node src/scripts/initData.js",
    "init:admin": "node src/scripts/createAdmin.js",
    "init": "npm run init:data && npm run init:admin",
    "worker": "node src/tasks/processors.js"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "bullmq": "^5.1.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "openai": "^4.20.1",
    "puppeteer": "^21.6.1",
    "sequelize": "^6.35.2",
    "sqlite3": "^6.0.1",
    "useragent": "^2.3.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
