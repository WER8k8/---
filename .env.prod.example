# ============================================
# 优丁建材 - 生产环境配置
# 使用方法：复制此文件为 .env.prod 并填入实际值
# ============================================

# 域名配置（修改为实际部署域名）
DOMAIN=www.youdingjiancai.com

# 数据库配置
DB_NAME=youding_prod
DB_USER=youding_admin
DB_PASSWORD=your-secure-db-password-change-me

# JWT密钥（必须使用强随机字符串）
# 生成命令：python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET_KEY=your-jwt-secret-key-here-change-me

# 英伟达API配置
AI_NVIDIA_API_KEY=nvapi-your-api-key-here

# MinIO对象存储配置
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# ============================================
# 邮件服务配置（必填，否则询盘通知无法发送）
# ============================================
# 推荐使用阿里云企业邮箱、腾讯企业邮箱或SendGrid

# SMTP服务器地址
# 阿里云企业邮箱：smtp.qiye.aliyun.com
# 腾讯企业邮箱：smtp.exmail.qq.com
# SendGrid: smtp.sendgrid.net
SMTP_SERVER=smtp.qiye.aliyun.com

# SMTP端口（通常587或465）
SMTP_PORT=587

# 邮箱账号（发件人）
SMTP_USERNAME=noreply@youdingjiancai.com

# 邮箱密码或授权码
SMTP_PASSWORD=your-email-password-change-me

# 发件人邮箱地址（与SMTP_USERNAME相同）
FROM_EMAIL=noreply@youdingjiancai.com

# ============================================
# 可选配置
# ============================================
# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE_MB=20

# 限流配置（每分钟最大请求数）
RATE_LIMIT_MAX_REQUESTS=60
